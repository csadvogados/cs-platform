{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pip install -r requirements.txt"
  },
  "deploy": {
    "preDeployCommand": "alembic upgrade head",
        "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
